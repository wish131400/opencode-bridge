{
  "name": "opencode-bridge",
  "version": "2.9.59",
  "type": "module",
  "description": "Feishu / Discord × OpenCode bridge service with runtime cron and reliability tooling",
  "main": "dist-electron/main.js",
  "types": "dist/index.d.ts",
  "author": "HNGM-HP",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/HNGM-HP/opencode-bridge#readme",
  "bin": {
    "opencode-bridge": "bin/opencode-bridge.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "preinstall": "node scripts/setup-mirror.mjs",
    "dev": "tsx watch src/index.ts",
    "dev:electron": "npm run build:electron && electron .",
    "build": "tsc",
    "build:web": "cd web && pnpm install && pnpm run build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:all": "npm run build:web && npm run build && npm run build:electron",
    "rebuild": "electron-rebuild -f -w better-sqlite3 -v",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node scripts/start.mjs",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build",
    "deploy:bridge": "node scripts/deploy.mjs deploy",
    "manage:bridge": "node scripts/deploy.mjs menu",
    "start:bridge": "node scripts/start.mjs",
    "stop:bridge": "node scripts/stop.mjs"
  },
  "keywords": [
    "feishu",
    "discord",
    "opencode",
    "bridge",
    "cli",
    "chatbot",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HNGM-HP/opencode-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/HNGM-HP/opencode-bridge/issues"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.36.3",
    "@opencode-ai/sdk": "latest",
    "@wecom/aibot-node-sdk": "^1.0.4",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "dingtalk-stream": "^2.1.4",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "grammy": "^1.41.1",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.4",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@grammyjs/types": "^3.25.0",
    "@hapi/boom": "^10.0.1",
    "@types/axios": "^0.14.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/pino": "^7.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.6",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "pino": "^10.3.1",
    "puppeteer": "^24.40.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.github.hngm-hp.opencode-bridge",
    "productName": "OpenCode Bridge",
    "copyright": "Copyright © 2024 HNGM-HP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/*.ts",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,LICENSE,license}",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,__pycache__,thumbs.db,.gitignore,.gitattributes,.flowconfig,.jshintrc,.eslintrc,.eslintignore,.idea,.vscode,.github}",
      "!web/node_modules",
      "!web/src"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "app/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "app/assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts",
        "to": "app/scripts",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenCode Bridge",
      "include": "installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon-1024.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSHighResolutionCapable": true,
        "CFBundleShortVersionString": "${version}"
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Network;Chat;InstantMessaging;"
    }
  }
}
